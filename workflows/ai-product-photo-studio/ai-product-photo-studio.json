      "id": "poll-status-001",
      "name": "Poll Task Status",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1680, 220],
      "typeVersion": 4.2
    },
    {
      "parameters": {
        "jsCode": "// Check task state and route success / fail / keep polling.\nconst state = $input.first().json.data?.state || 'unknown';\nconst taskId = $('Create Task').first().json.data?.taskId || '';\n\nif (state === 'success') {\n  let imageUrl = '';\n  try {\n    const resultJson = JSON.parse($input.first().json.data.resultJson);\n    imageUrl = resultJson.resultUrls[0] || '';\n  } catch (e) {\n    imageUrl = 'PARSE_ERROR: ' + e.message;\n  }\n  return [{\n    json: {\n      status: 'success',\n      image_url: imageUrl,\n      prompt_used: $('Data Cleanup').first().json.clean_prompt,\n      source_image: $('Data Cleanup').first().json.image_url,\n      model: 'nano-banana-2',\n      taskId\n    }\n  }];\n} else if (state === 'fail') {\n  return [{\n    json: {\n      status: 'failed',\n      reason: 'Task failed on KIE.AI',\n      taskId,\n      state\n    }\n  }];\n} else {\n  // Still processing - pass through for the retry loop\n  return [{\n    json: {\n      ...($input.first().json),\n      _status: 'polling',\n      _state: state\n    }\n  }];\n}"
      },
