    {
      "parameters": {
        "jsCode": "// Convert the uploaded photo to a base64 data URL for the KIE.AI upload step.\nconst item = $input.first();\nconst binKeys = Object.keys(item.binary || {});\nif (!binKeys.length) {\n  throw new Error('No file received. Make sure the \"Pick a Photo\" field has an image.');\n}\nconst key = binKeys[0];\nconst meta = item.binary[key];\nconst buffer = await this.helpers.getBinaryDataBuffer(0, key);\nconst mime = meta.mimeType || 'image/png';\nconst ext = (meta.fileExtension || 'png').replace('.', '');\nreturn [{\n  json: {\n    base64Data: `data:${mime};base64,${buffer.toString('base64')}`,\n    fileName: `input-${Date.now()}.${ext}`,\n    photo_type: item.json['Photo Type'] || 'Custom (use prompt only)',\n    aspect_ratio: item.json['Aspect Ratio'] || '1:1',\n    scene: item.json['Describe the Scene'] || ''\n  }\n}];"
      },
      "id": "prep-upload-001",
      "name": "Prepare Upload",
      "type": "n8n-nodes-base.code",
      "position": [160, 220],
      "typeVersion": 2
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.kie.ai/api/file-base64-upload",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ base64Data: $json.base64Data, uploadPath: 'product-photos/input', fileName: $json.fileName }) }}",
        "options": {}
      },
      "id": "upload-input-001",
      "name": "Upload Input to KIE",
      "type": "n8n-nodes-base.httpRequest",
      "position": [380, 220],
